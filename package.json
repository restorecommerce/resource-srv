{
  "name": "@restorecommerce/resource-srv",
  "version": "1.5.1",
  "description": "Restore Commerce Resource Microservice",
  "main": "lib/start.js",
  "author": "n-fuse GmbH",
  "repository": {
    "type": "git",
    "url": "https://github.com/restorecommerce/resource-srv.git"
  },
  "license": "MIT",
  "keywords": [
    "restore",
    "commerce",
    "microservice",
    "resource"
  ],
  "type": "module",
  "dependencies": {
    "@restorecommerce/acs-client": "^3.1.9",
    "@restorecommerce/grpc-client": "^2.2.13",
    "@restorecommerce/kafka-client": "^1.3.8",
    "@restorecommerce/logger": "^1.3.8",
    "@restorecommerce/rc-grpc-clients": "^5.1.64",
    "@restorecommerce/resource-base-interface": "^1.9.13",
    "@restorecommerce/service-config": "^1.1.7",
    "lodash-es": "^4.17.23",
    "redis": "^5.10.0"
  },
  "devDependencies": {
    "@alenon/grpc-mock-server": "^3.2.6",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@grpc/proto-loader": "^0.8.0",
    "@restorecommerce/dev": "^0.2.0",
    "@restorecommerce/protos": "^6.12.0",
    "@semantic-release-plus/docker": "^3.1.3",
    "@types/lodash-es": "^4.17.12",
    "@types/mocha": "^10.0.10",
    "@types/nconf": "^0.10.7",
    "@types/node": "^25.2.1",
    "@types/redis": "^4.0.11",
    "@types/uuid": "^11.0.0",
    "c8": "^10.1.3",
    "coveralls": "^3.1.1",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.11",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.2",
    "should": "^13.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "scripts": {
    "start": "node ./lib/start.cjs",
    "dev": "cross-env NODE_ENV=development nodemon --watch './src/**/*.ts' --exec node --loader ts-node/esm ./src/start.ts",
    "tsctests": "tsc -d -p tsconfig.test.json",
    "test": "npm run lint && c8 --reporter=text npm run mocha",
    "lint": "eslint src",
    "mocha": "cross-env NODE_ENV=test mocha --full-trace --exit --timeout 30000",
    "mochadebug": "cross-env NODE_ENV=test; mocha -R spec ./test/*.js --full-trace --inspect-brk",
    "lcov-report": "c8 report --reporter=lcov",
    "coveralls": "c8 report --reporter=text-lcov | coveralls",
    "build:es": "node ./esbuild.mjs",
    "build:clean": "rimraf lib",
    "build": "npm-run-all lint build:clean build:es",
    "prepare": "node -e \"try { require('husky').install() } catch (e) {}\""
  },
  "engines": {
    "node": ">= 24.10.0"
  },
  "release": {
    "branches": [
      "master"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/github",
      [
        "@semantic-release-plus/docker",
        {
          "name": "docker.io/restorecommerce/resource-srv",
          "skipLogin": true
        }
      ],
      [
        "@semantic-release-plus/docker",
        {
          "name": "ghcr.io/restorecommerce/resource-srv",
          "skipLogin": true
        }
      ]
    ]
  }
}
